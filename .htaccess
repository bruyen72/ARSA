# Roteia todas as requisições que NÃO sejam arquivos/pastas existentes
# para o index.php (roteador único do site).

RewriteEngine On

# Se o arquivo ou pasta solicitados existem de verdade (CSS, JS, imagens,
# uploads, etc.), serve normalmente sem passar pelo roteador.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Caso contrário, envia para o roteador PHP.
RewriteRule ^ index.php [L]

# Cache longo para arquivos estáticos (1 ano)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg        "access plus 1 year"
    ExpiresByType image/png         "access plus 1 year"
    ExpiresByType image/webp        "access plus 1 year"
    ExpiresByType image/svg+xml     "access plus 1 year"
    ExpiresByType text/css          "access plus 1 